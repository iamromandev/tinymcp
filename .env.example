# auth: "auth0" (default) or "clerk"
AUTH_PROVIDER=auth0

# --- Auth0 (when AUTH_PROVIDER=auth0) ---
# Copy the Domain from Auth0 Dashboard → Settings → Domain
AUTH0_DOMAIN=your-tenant.us.auth0.com
AUTH0_CLIENT_ID=your-auth0-client-id
AUTH0_CLIENT_SECRET=your-auth0-client-secret
AUTH0_AUDIENCE=your-auth0-api-audience

# --- Clerk as IdP (when AUTH_PROVIDER=clerk) ---
# Discovery URL from Clerk Dashboard → OAuth application
# CLERK_CONFIG_URL=https://your-frontend-api/.well-known/openid-configuration
# CLERK_CLIENT_ID=your-clerk-oauth-client-id
# CLERK_CLIENT_SECRET=your-clerk-oauth-client-secret
# Optional: JWT audience on access tokens (omit if verifying id_token only)
# CLERK_AUDIENCE=
# Set true if access tokens are opaque; validates OIDC id_token instead
# CLERK_VERIFY_ID_TOKEN=false
# Optional: override requested scopes (must match scopes enabled on the Clerk OAuth app)
# CLERK_SCOPES=profile email
# With openid enabled in Clerk Dashboard: CLERK_SCOPES=openid profile email

BASE_URL=http://localhost:8000
